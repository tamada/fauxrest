{
  "grants": {
    "ids": {
      "$emit": ["ids"],
      "$filter": [{ "field": "secret", "op": "eq", "value": false }]
    },
    "$filter": [{ "field": "secret", "op": "eq", "value": false }],
    "$emit": ["list"],
    "current": {
      "$emit": ["list"],
      "$filter": [{ "field": "status", "op": "eq", "value": "continued" }]
    }
  },
  "members": {
    "ids": {
      "$emit": ["ids"],
      "$filter": [{ "field": "category", "op": "neq", "value": "non_member" }]
    },
    "$emit": ["list"],
    "$filter": [{ "field": "category", "op": "neq", "value": "non_member" }],
    "${category}": {
      "$emit": ["list"],
      "$derive": { "field": "category", "pattern": ".*" },
      "$filter": [
        { "field": "category", "op": "eq", "value": "{category}" },
        { "field": "category", "op": "neq", "value": "non_member" }
      ]
    }
  },
  "theses": {
    "ids": {
      "$emit": ["ids"],
      "$filter": [{ "field": "hide", "op": "eq", "value": false }]
    },
    "$emit": ["list"],
    "$filter": [{ "field": "hide", "op": "eq", "value": false }],
    "types/master": {
      "$emit": ["list"],
      "$filter": [{ "field": "type", "op": "eq", "value": "masterthesis" }]
    },
    "types/bachelor": {
      "$emit": ["list"],
      "$filter": [{ "field": "type", "op": "eq", "value": "bachelorthesis" }]
    },
    "types/doctor": {
      "$emit": ["list"],
      "$filter": [{ "field": "type", "op": "eq", "value": "phdthesis" }]
    },
    "years": {
      "$emit": [],
      "${year}": {
        "$emit": ["list"],
        "$derive": { "field": "year", "pattern": ".*" },
        "$filter": [
          {
            "field": "year",
            "op": "eq",
            "value": "{year}"
          }
        ]
      }
    }
  },
  "papers": {
    "ids": {
      "$emit": ["ids"],
      "$filter": [{ "field": "hide", "op": "eq", "value": false }]
    },
    "$emit": ["list"],
    "$filter": [{ "field": "hide", "op": "eq", "value": false }],
    "years": {
      "$emit": [],
      "${year}": {
        "$emit": ["list"],
        "$derive": { "field": "year", "pattern": ".*" },
        "$filter": [
          {
            "field": "year",
            "op": "eq",
            "value": "{year}"
          }
        ]
      }
    },
    "types": {
      "$emit": [],
      "${type}": {
        "$emit": ["list"],
        "$derive": { "field": "type", "pattern": ".*" },
        "$filter": [{ "field": "type", "op": "eq", "value": "{type}" }]
      }
    },
    "languages/english": {
      "$emit": ["list"],
      "$filter": [{ "field": "language", "op": "eq", "value": "english" }]
    },
    "languages/japanese": {
      "$emit": ["list"],
      "$filter": [{ "field": "language", "op": "eq", "value": "japanese" }]
    }
  }
}
